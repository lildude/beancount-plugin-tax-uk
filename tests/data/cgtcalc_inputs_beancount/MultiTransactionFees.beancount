option "title" "MultiTransactionFees"
option "operating_currency" "GBP"

1970-01-01 open Assets:MorganStanley:MSFT                        "FIFO"
1970-01-01 open Assets:MorganStanley:Cash                        "FIFO"
1970-01-01 open Assets:Cash:Wise:USD                             "FIFO"
1970-01-01 open Assets:Cash:Wise:GBP                             "FIFO"
1970-01-01 open Assets:Cash:Starling:Current                     "FIFO"
1970-01-01 open Expenses:USInvestments:Fees                      "FIFO"
1970-01-01 open Expenses:Wise:USD:Fees                           "FIFO"
1970-01-01 open Expenses:Wise:GBP:Fees                           "FIFO"
1970-01-01 open Income:Investments:USTaxable:CapitalGains        "FIFO"

1970-01-01 custom "uk-tax-config" "ignored-currencies" "GBP" "USD"
1970-01-01 custom "uk-tax-config" "commission-account" "Expenses:USInvestments:Fees"

1970-01-01 commodity MSFT
1970-01-01 commodity GBP
1970-01-01 commodity USD

